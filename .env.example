# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/doc_processing
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=["application/pdf","image/jpeg","image/png","image/tiff"]

# Processing
PROCESSING_TIMEOUT=300
MAX_RETRY_ATTEMPTS=3
BATCH_SIZE=10

# OCR Configuration
TESSERACT_CMD=
OCR_LANGUAGE=eng
OCR_CONFIG=--oem 3 --psm 6

# NLP Configuration
SPACY_MODEL=en_core_web_sm
TRANSFORMERS_CACHE_DIR=ml_models/cache

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=8001

# Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# External APIs
OPENAI_API_KEY=
AZURE_OCR_KEY=
AZURE_OCR_ENDPOINT=

# Development
DEBUG=false
RELOAD=true
